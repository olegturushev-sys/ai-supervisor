# Hugging Face access token (optional) for WhisperX models or GigaAM longform VAD (pyannote/segmentation-3.0).
# Generate at https://huggingface.co/settings/tokens and accept model agreements as needed.
HF_TOKEN=

# Backend defaults (optional)
ASR_ENGINE=gigaam
GIGAAM_MODEL=v3_e2e_rnnt
LONGFORM_MIN_SECONDS=10
# Parallel segments per job. 4 recommended for Apple Silicon (M1/M2/M3).
SEGMENT_CONCURRENCY=4
# VAD for longform: lower threshold (0.8) = more speech detected; boundary padding (s) to reduce cutoff at edges
VAD_THRESHOLD_SCALE=0.9
VAD_BOUNDARY_PADDING_S=0.3
# Fill gaps between VAD segments: transcribe regions ≥ this many seconds that VAD labeled as silence
VAD_GAP_FILL_MIN_S=1.5
WHISPERX_MODEL=tiny
WHISPERX_LANGUAGE=ru
WHISPERX_BATCH_SIZE=8
JOBS_CONCURRENCY=1

# Diarization (optional).
# Engine: local (transcript + ECAPA + sklearn) | fast (Silero VAD + ECAPA + Mean Shift)
DIARIZATION_ENGINE=fast
# Diarization-first: run diarization before transcription, transcribe each diar segment (better speaker coverage)
DIARIZATION_FIRST=1
# If set to 1/true/yes, diarization failures will FAIL the job instead of being skipped.
DIARIZATION_REQUIRED=0
DIARIZATION_DEFAULT_SPEAKERS=2
# Therapy mode: always 2 speakers (client/therapist), client = more utterances
DIARIZATION_THERAPY_MODE=1
# DIARIZATION_CLIENT_LABEL=Клиент
# DIARIZATION_THERAPIST_LABEL=Терапевт
# Local diarization: segment filtering and splitting
DIARIZATION_MIN_SEGMENT_S=0.8
DIARIZATION_MAX_SEGMENT_S=8
DIARIZATION_SUBSEGMENT_S=2.5
DIARIZATION_MIN_RMS=0
# Embedding model (SpeechBrain): ecapa-voxceleb (default), ecapa-voxceleb-m (larger), xvect-voxceleb
DIARIZATION_EMBEDDING_MODEL=speechbrain/spkrec-ecapa-voxceleb
DIARIZATION_LOCAL_BATCH=8
# Clustering: agglomerative|spectral|refined
DIARIZATION_CLUSTERING=agglomerative
DIARIZATION_SMOOTH_LABELS=1
DIARIZATION_RMS_NORMALIZE=1
# Fast engine (Silero VAD + ECAPA + Mean Shift):
DIARIZATION_FAST_VAD_THRESHOLD=0.5
DIARIZATION_FAST_MIN_SPEECH_MS=250
DIARIZATION_FAST_MIN_SILENCE_MS=100
DIARIZATION_FAST_MEAN_SHIFT_BANDWIDTH=0.4
# Total CPU load ~ JOBS_CONCURRENCY * SEGMENT_CONCURRENCY

# If you want to disable WhisperX processing (dev / smoke):
WHISPERX_DISABLE=0

# Device/compute_type selection:
# - ASR uses faster-whisper/ctranslate2 which does NOT support mps.
# - So on macOS we use CPU + int8 by default (stable, predictable).

# OpenRouter API (https://openrouter.ai/keys) - for therapy session analysis
OPENROUTER_API_KEY=

# QWEN CLI - full path to qwen executable for local analysis
# Example: /usr/local/bin/qwen or ~/.local/bin/qwen
# Leave empty to disable QWEN CLI analysis
QWEN_CLI_PATH=


